{
  "name": "delamain-dashboard",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "smoke:design": "bun run src/smoke-design.ts",
    "smoke:design:compact": "bun run src/smoke-design.ts --compact",
    "start": "bun run src/index.ts service",
    "service": "bun run src/index.ts service",
    "tui": "bun run src/index.ts tui",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "0.1.96"
  },
  "optionalDependencies": {
    "@opentui/core-darwin-arm64": "0.1.96",
    "@opentui/core-darwin-x64": "0.1.96",
    "@opentui/core-linux-arm64": "0.1.96",
    "@opentui/core-linux-x64": "0.1.96",
    "@opentui/core-win32-arm64": "0.1.96",
    "@opentui/core-win32-x64": "0.1.96"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
