{
  "schema": "als-construct-manifest@1",
  "name": "dashboard",
  "version": 1,
  "migration_strategy": "sequential",
  "lifecycle_strategy": "process-lifecycle",
  "migrations_dir": "migrations",
  "source_paths": [
    {
      "path": "VERSION",
      "owner": "vendor"
    },
    {
      "path": "construct.json",
      "owner": "vendor"
    },
    {
      "path": "README.md",
      "owner": "vendor"
    },
    {
      "path": "bun.lock",
      "owner": "vendor"
    },
    {
      "path": "package.json",
      "owner": "vendor"
    },
    {
      "path": "scripts",
      "owner": "vendor"
    },
    {
      "path": "src",
      "owner": "vendor"
    },
    {
      "path": "tsconfig.json",
      "owner": "vendor"
    }
  ]
}
