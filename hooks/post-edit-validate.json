{
  "description": "Runs ALS compiler against the affected module after file edits",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun $CLAUDE_PLUGIN_ROOT/hooks/als-validate.ts",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
