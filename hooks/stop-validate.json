{
  "description": "Final validation gate — blocks Claude from finishing if any ALS system has errors",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $CLAUDE_PLUGIN_ROOT/hooks/als-stop-gate.ts",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
